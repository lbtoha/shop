meta {
  name: login with 2fa
  type: http
  seq: 10
}

post {
  url: {{url}}/auth/sign-in-with-2fa
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  User-Agent: insomnia/9.3.3
  accept: application/json
}

body:json {
  {
      "email":"user@gmail.com",
      "otp":"12345"
  }
}

script:post-response {
  test("token", function () {
      var jsonData = res.getBody();
      bru.setEnvVar("token", jsonData?.data?.token);
  
  });
}
