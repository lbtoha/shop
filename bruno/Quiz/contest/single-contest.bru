meta {
  name: single-contest
  type: http
  seq: 4
}

get {
  url: {{url}}/single-contest/{{contest_slug}}?with_questions=true
  body: none
  auth: bearer
}

params:query {
  with_questions: true
}

headers {
  User-Agent: insomnia/9.3.3
  accept: application/json
}

auth:bearer {
  token: {{token}}
}
