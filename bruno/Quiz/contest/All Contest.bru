meta {
  name: All Contest
  type: http
  seq: 2
}

get {
  url: {{url}}/get-contests?per_page=1000
  body: multipartForm
  auth: bearer
}

params:query {
  per_page: 1000
  ~search: Hardware Troubleshooting
  ~page: 1
}

headers {
  User-Agent: insomnia/9.3.3
  accept: application/json
}

auth:bearer {
  token: {{token}}
}
